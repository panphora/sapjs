{
  "name": "@panphora/sapjs",
  "version": "0.2.1",
  "description": "A reactive HTML library where the DOM is the only state store. Structure-first, one write path, transient rebuild. An Alpine alternative built for malleable, self-saving HTML.",
  "type": "module",
  "main": "src/sap.js",
  "exports": {
    ".": "./src/sap.js"
  },
  "jsdelivr": "dist/sap.min.js",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build/bundle.mjs",
    "build:docs": "node scripts/build-doc.mjs",
    "copy-to-hyperclayjs": "npm run build && node scripts/copy-to-hyperclayjs.js",
    "copy-to-clayjs": "npm run build && node scripts/copy-to-clayjs.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "serve": "node build/bundle.mjs && python3 -m http.server 8123"
  },
  "keywords": [
    "reactive",
    "html",
    "dom",
    "alpine",
    "hyperclay",
    "malleable",
    "no-build"
  ],
  "author": "panphora",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panphora/sapjs.git"
  },
  "homepage": "https://saphtml.com",
  "bugs": {
    "url": "https://github.com/panphora/sapjs/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "esbuild": "^0.21.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "hyper": {
    "kind": "lib",
    "status": "active",
    "url": "https://saphtml.com"
  }
}
